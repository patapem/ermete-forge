// Enterprise Niri configuration for the AGS graphical greeter (Ermete OS)
hotkey-overlay {
    skip-at-startup
}

// Pure Rust native GTK4 greeter execution with fallback paths and log capture
spawn-at-startup "sh" "-c" "mkdir -p /tmp/greeter-cache /var/lib/greetd/.cache && chmod 1777 /tmp/greeter-cache 2>/dev/null || true; if [ -x /usr/bin/ermete-shell-rs ]; then BIN=/usr/bin/ermete-shell-rs; elif [ -x /usr/local/bin/ermete-shell-rs ]; then BIN=/usr/local/bin/ermete-shell-rs; else BIN=ermete-shell-rs; fi; XDG_CACHE_HOME=/tmp/greeter-cache GREETD_SOCK=$GREETD_SOCK exec $BIN --greeter > /tmp/greeter-rs.log 2>&1"

// Ensure any window opened in the greeter session is full-screen and maximized
window-rule {
    open-fullscreen true
    open-maximized true
    geometry-corner-radius 0
    clip-to-geometry true
}

layout {
    default-column-width { proportion 1.0; }
    focus-ring {
        off
    }
    border {
        off
    }
}

animations {
    window-open {
        off
    }
}

binds {
    // Disable all shortcuts to prevent greeter escape
}
