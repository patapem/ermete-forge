[rpmfusion-free]
name=RPM Fusion for Fedora 43 - Free
baseurl=http://mirrors.rpmfusion.org/free/fedora/releases/43/Everything/$basearch/os/
enabled=1
gpgcheck=0
skip_if_unavailable=1

[rpmfusion-nonfree]
name=RPM Fusion for Fedora 43 - Nonfree
baseurl=http://mirrors.rpmfusion.org/nonfree/fedora/releases/43/Everything/$basearch/os/
enabled=1
gpgcheck=0
skip_if_unavailable=1
