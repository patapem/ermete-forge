%_optflags -O3 -march=x86-64-v3 -mtune=native -flto=auto -fno-semantic-interposition -falign-functions=32 -fno-math-errno -fno-trapping-math
%_ldflags -Wl,-O2 -Wl,--as-needed -Wl,--sort-common -Wl,-z,now -Wl,-z,relro -flto=auto -fuse-ld=mold
%_lto_cflags -flto=auto -fno-semantic-interposition

%__global_compiler_flags -O3 -march=x86-64-v3 -mtune=native -flto=auto -fno-semantic-interposition -falign-functions=32 -fno-math-errno -fno-trapping-math
%__global_ldflags -Wl,-O2 -Wl,--as-needed -Wl,--sort-common -Wl,-z,now -Wl,-z,relro -flto=auto -fuse-ld=mold

# Rust/Cargo extreme optimization flags
%__cargo_common_opts --locked
%rustflags -C target-cpu=x86-64-v3 -C opt-level=3 -C lto=thin -C embed-bitcode=yes -C link-arg=-fuse-ld=mold

# Enable parallel builds matching available cores
%_smp_mflags -j%{_smp_build_ncpus}
